{
  "name": "claude-gitlab-agent",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-powered GitLab assistant for code review, Q&A, and MR creation using Claude",
  "license": "MIT",
  "author": "Claude GitLab Agent Contributors",
  "homepage": "https://github.com/claude-agent/claude-gitlab-agent",
  "repository": {
    "type": "git",
    "url": "https://github.com/claude-agent/claude-gitlab-agent.git"
  },
  "keywords": [
    "gitlab",
    "claude",
    "ai",
    "code-review",
    "merge-request",
    "assistant",
    "anthropic"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "@hono/node-server": "^1.0.0",
    "simple-git": "^3.22.0",
    "bullmq": "^5.1.0",
    "ioredis": "^5.3.0",
    "ky": "^1.2.0",
    "zod": "^3.22.0",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.0",
    "dotenv": "^16.4.0",
    "@anthropic-ai/sdk": "^0.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
